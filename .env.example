# =============================================================================
# AI Website Powerhouse — environment template
# =============================================================================
#
# Copy this file to `.env.local` and fill in only the variables you actually
# need. `.env.local` is gitignored. Never commit real secrets to this repo.
#
# Variables are grouped by what feature they unlock. The CURRENT BUILD only
# reads the OpenRouter group. Everything else is reserved for the in-progress
# SaaS rewrite — leaving them blank is fine for now.
#
# =============================================================================


# -----------------------------------------------------------------------------
# OpenRouter — server-side proxy fallback  (CURRENT BUILD)
# -----------------------------------------------------------------------------
# Read by: app/api/openrouter/route.ts
#
# When OPENROUTER_API_KEY is set, the /api/openrouter route accepts unauthenticated
# POST requests from the browser and forwards them to OpenRouter using this key.
# When unset, the route returns 503 and the browser must fall back to a
# user-pasted key entered in the in-app Settings panel.
#
# WARNING: do NOT set this on a public deployment without first adding
# per-IP rate limits and a daily spend cap. Without those, anyone hitting your
# /api/openrouter endpoint can spend your OpenRouter credits.
OPENROUTER_API_KEY=

# Optional. Sent as the `HTTP-Referer` header on outbound OpenRouter calls.
# OpenRouter uses this for attribution on their app-rankings page.
# Set to your deployment's public origin, e.g. https://ai-website-powerhouse.com
OPENROUTER_REFERER=

# Optional. Sent as the `X-Title` header. Defaults to "AI Website Powerhouse"
# when unset; override only if you've forked and renamed.
OPENROUTER_TITLE=


# -----------------------------------------------------------------------------
# Supabase — auth and database  (RESERVED for SaaS rewrite; not yet read)
# -----------------------------------------------------------------------------
# Get from your Supabase project's API settings page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key is server-only. Never expose it to the browser. Used by
# admin endpoints and the auth-trigger that mirrors auth.users into public.users.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# Stripe — billing  (RESERVED for SaaS rewrite; not yet read)
# -----------------------------------------------------------------------------
# Use Test mode keys (`sk_test_…`, `pk_test_…`) during development.
# Flip to Live mode keys only at launch.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret, generated when you register the webhook endpoint
# in the Stripe dashboard. Required for /api/stripe/webhook to verify
# signatures and reject forged events.
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting  (RESERVED for SaaS rewrite; not yet read)
# -----------------------------------------------------------------------------
# REST URL and token from the Upstash console. The free tier is sufficient
# until launch.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# Cloudflare Turnstile — sign-up CAPTCHA  (RESERVED for SaaS rewrite)
# -----------------------------------------------------------------------------
# Site key is sent to the browser. Secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Sentry — error monitoring  (RESERVED for SaaS rewrite)
# -----------------------------------------------------------------------------
# DSN is safe to expose; it identifies the project, not your account.
NEXT_PUBLIC_SENTRY_DSN=


# -----------------------------------------------------------------------------
# PostHog — product analytics  (RESERVED for SaaS rewrite)
# -----------------------------------------------------------------------------
# Project API key (publishable) and host. Self-hosted PostHog users
# override the host; cloud users leave it at the default.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# -----------------------------------------------------------------------------
# Resend — transactional email  (RESERVED for SaaS rewrite)
# -----------------------------------------------------------------------------
# Server-only API key for sending verification emails, password resets,
# receipts, etc.
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# AIWP encryption — at-rest secrets  (RESERVED for SaaS rewrite)
# -----------------------------------------------------------------------------
# 32-byte (64-hex-char) symmetric key used to AES-256-GCM encrypt user-stored
# secrets in the database (e.g. user-saved provider keys, GitHub OAuth tokens,
# Vercel deploy tokens). Generate with:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# This key is version 1. Rotating it requires re-encrypting all rows and
# bumping the key_version column. Never commit a real value here.
AIWP_ENCRYPTION_KEY=
AIWP_ENCRYPTION_KEY_VERSION=1


# -----------------------------------------------------------------------------
# Sentry / PostHog / Resend etc. above are *server* env vars unless prefixed
# with NEXT_PUBLIC_. Next.js inlines NEXT_PUBLIC_* into the client bundle, so
# treat anything with that prefix as public knowledge once deployed.
# -----------------------------------------------------------------------------
